# Async SQLAlchemy application database URL for production.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/securedesk

# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/securedesk

# Required for JWT signing. Set this to a random 256-bit secret in each environment.
SECRET_KEY=change-this-to-a-random-256-bit-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File upload storage and limits.
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Use development locally and production on Railway.
ENVIRONMENT=development

# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
