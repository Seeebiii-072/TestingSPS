# SPS SecureDesk AI — Backend Environment Configuration
# ======================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# --- Database ---
# For local SQLite development:
DATABASE_URL=sqlite+aiosqlite:///./securedesk.db
DATABASE_URL_SYNC=sqlite:///./securedesk.db
# For production PostgreSQL (Render, AWS RDS, etc.):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/securedesk
# DATABASE_URL_SYNC=postgresql://user:password@host:5432/securedesk

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Internal API Key ---
# Shared secret between backend and email_worker for service-to-service auth
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=replace-with-a-random-internal-api-key

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# --- Environment ---
# Use "development" locally, "production" in deployment
ENVIRONMENT=development

# --- Seed Users ---
# Set to "true" only for local/dev demo accounts
# NEVER enable in production
SEED_DEFAULT_USERS=false

# --- AI Service ---
# URL of the AI classification service
AI_SERVICE_URL=http://localhost:8001