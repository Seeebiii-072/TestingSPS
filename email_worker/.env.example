# =============================================================================
# SPS SecureDesk AI — Email Worker Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Variables marked [REQUIRED] must be set. [OPTIONAL] have safe defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# IMAP — Inbound email polling
# -----------------------------------------------------------------------------
# [REQUIRED] For local dev with Mailhog: IMAP_HOST=mailhog, IMAP_PORT=1143
# [REQUIRED] For production: use your real IMAP server credentials
IMAP_HOST=mailhog
IMAP_PORT=1143
IMAP_USER=testuser
IMAP_PASSWORD=testpass

# [OPTIONAL] How often to poll the IMAP inbox (seconds). Default: 30
IMAP_POLL_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# SMTP — Outbound email sending
# -----------------------------------------------------------------------------
# [OPTIONAL] For local dev with Mailhog: SMTP_HOST=mailhog, SMTP_PORT=1025 (no auth needed)
# [REQUIRED] For production: use your real SMTP server credentials
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# [OPTIONAL] Sender identity shown in outbound emails
EMAIL_FROM_ADDRESS=helpdesk@sps.com
EMAIL_FROM_NAME=SPS Helpdesk

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# [REQUIRED] URL of the backend service (Docker service name in compose)
BACKEND_API_URL=http://backend:8000

# -----------------------------------------------------------------------------
# AI Classification Service
# -----------------------------------------------------------------------------
# [REQUIRED] URL of the AI service (Docker service name in compose)
AI_SERVICE_URL=http://ai_service:8001

# -----------------------------------------------------------------------------
# Portal
# -----------------------------------------------------------------------------
# [OPTIONAL] Base URL of the frontend portal (used in email links)
PORTAL_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Internal Storage
# -----------------------------------------------------------------------------
# [OPTIONAL] Path to the directory where message_store.json is persisted.
# Default: email_worker/data/ (relative to the package root)
# In Docker: set to /app/email_worker/data and mount a named volume there.
MESSAGE_STORE_PATH=/app/email_worker/data